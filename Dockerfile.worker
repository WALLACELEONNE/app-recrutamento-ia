# Build Stage
FROM golang:alpine AS builder

WORKDIR /app

# Instala dependências de sistema necessárias
RUN apk add --no-cache gcc musl-dev

# Baixa as dependências Go
COPY go.mod go.sum ./
RUN go mod download

# Copia o código-fonte
COPY . .

# Compila o binário do Worker otimizado (sem debug info)
RUN CGO_ENABLED=0 GOOS=linux go build -ldflags="-w -s" -o worker ./cmd/worker

# Runtime Stage
FROM alpine:3.19

WORKDIR /app

# Adiciona certificados SSL e fuso horário
RUN apk --no-cache add ca-certificates tzdata

# Configuração de Timezone (Horário de Brasília) e Encoding (UTF-8)
ENV TZ=America/Sao_Paulo
ENV LANG=C.UTF-8
ENV LC_ALL=C.UTF-8

# Copia o binário compilado do estágio anterior
COPY --from=builder /app/worker .

# Como o Worker atua como cliente consumindo serviços (LiveKit, OpenAI, etc),
# não precisamos expor portas. O Healthcheck verificará se o processo continua rodando.

# Comando de inicialização
CMD ["./worker"]
