# Database (PostgreSQL)
POSTGRES_USER=admin
POSTGRES_PASSWORD=password
POSTGRES_DB=recrutamento_db
DATABASE_URL=postgres://admin:password@127.0.0.1:5432/recrutamento_db?sslmode=disable

# Cache / Sessions (Redis)
REDIS_URL=127.0.0.1:6379

# Encoding e Timezone Padrão (Local e Railway)
TZ=America/Sao_Paulo
LANG=C.UTF-8
LC_ALL=C.UTF-8

# Server Config
PORT=3000
APP_ENV=development

# LiveKit Config (Host local)
LIVEKIT_URL=ws://127.0.0.1:7880
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=secret

# IA Providers (API Keys)
DEEPGRAM_API_KEY=sua_chave_deepgram_aqui
OPENAI_API_KEY=sua_chave_openai_aqui
ELEVENLABS_API_KEY=sua_chave_elevenlabs_aqui
ELEVENLABS_VOICE_ID=sua_voice_id_aqui
